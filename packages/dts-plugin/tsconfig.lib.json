{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "declaration": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "types": ["node", "fs-extra"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "__tests__/**",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "rslib.config.ts",
    "jest.config.ts"
  ]
}
